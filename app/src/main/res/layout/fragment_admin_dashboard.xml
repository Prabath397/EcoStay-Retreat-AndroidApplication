<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Dashboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnManageRooms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage Rooms"
        android:backgroundTint="@color/primary_green"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnManageActivities"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage Activities"
        android:backgroundTint="@color/primary_green"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAllBookings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View All Bookings"
        android:backgroundTint="@color/primary_green"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSendNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Notification to All Users"
        android:backgroundTint="@color/primary_green"/>

</LinearLayout>