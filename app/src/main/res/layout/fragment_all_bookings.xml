<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Room Bookings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvNoRooms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No room bookings yet"
            android:textSize="16sp"
            android:textColor="@color/dark_gray"
            android:layout_marginBottom="24dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewRooms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Activity Bookings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvNoActivities"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No activity bookings yet"
            android:textSize="16sp"
            android:textColor="@color/dark_gray"
            android:layout_marginBottom="24dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewActivities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>